# Telegram Configuration
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
TELEGRAM_CHAT_ID="your_channel_or_group_chat_id"
TELEGRAM_WEBHOOK_SECRET="your_secure_random_webhook_secret_token"
TELEGRAM_ADMIN_USER_IDS="comma_separated_admin_user_ids"

# GitHub LLM Configuration
GITHUB_TOKEN="your_github_token"
MODEL_NAME="openai/gpt-4.1-nano"

# Supabase Database Configuration
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-secret-service-role-key"

# Optional: Admin Username for Access Denied contact message (e.g. @username)
TELEGRAM_ADMIN_USERNAME="@your_admin_username"
